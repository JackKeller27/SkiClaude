generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // For local dev, set DATABASE_URL to a Neon (or other Postgres) connection string in .env
  // SQLite was used during initial development
}

model Resort {
  id               Int      @id @default(autoincrement())
  name             String
  state            String
  lat              Float
  lng              Float
  passType         String   @default("INDEPENDENT") // IKON | EPIC | INDEPENDENT
  verticalDrop     Int      @default(0)
  numRuns          Int      @default(0)
  acreage          Int      @default(0)
  summitElevation  Int      @default(0)
  trips            Trip[]
  createdAt        DateTime @default(now())
}

model Trip {
  id           Int      @id @default(autoincrement())
  resort       Resort   @relation(fields: [resortId], references: [id])
  resortId     Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  date         DateTime
  visitNumber  Int
  companions   String   @default("")
  favoriteRun  String   @default("")
  notes        String   @default("")
  createdAt    DateTime @default(now())
}

// Auth.js required models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  trips         Trip[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
